# App
SERVER_PORT=8080
APP_API_BASE_URL=http://localhost:8080

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/vigigate
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# Risk engine
RISK_TIMEZONE=Asia/Jakarta
RISK_MODEL_VERSION=rules-v1
RISK_LOW_MAX=34
RISK_MEDIUM_MAX=69
RISK_BUSINESS_HOUR_START=7
RISK_BUSINESS_HOUR_END=20

# OpenAI portrait quality scoring
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=20000
OPENAI_IMAGE_DETAIL=low
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
OPENAI_SUMMARY_TIMEOUT_MS=20000

# Security JWT
SECURITY_JWT_SECRET=replace-with-a-32-char-min-dev-secret-key
SECURITY_JWT_ISSUER=vigigate-api
SECURITY_JWT_ACCESS_TTL_SECONDS=3600
SECURITY_JWT_REFRESH_TTL_SECONDS=604800
SECURITY_JWT_REFRESH_REMEMBERME_TTL_SECONDS=2592000

# Spring profile
SPRING_PROFILES_ACTIVE=dev

# Development seed data
APP_SEED_ENABLED=true
APP_SEED_WIPE=false
APP_SEED_BULK_VISITORS=300
APP_SEED_BULK_OPEN_ALERTS=45
APP_SEED_BULK_REPORTS=21
